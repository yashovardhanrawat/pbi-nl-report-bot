        "lineageTag": "254536ed-5a77-44d1-8297-19fa37ef80f7",
        "measures": [
          {
            "name": "Total Revenue",
            "expression": "SUM(fact_sales[revenue])",
            "lineageTag": "b80754f8-9527-4a87-858e-167a2b7f3b4d"
          },
          {
            "name": "Total Net Revenue",
            "expression": "SUM(fact_sales[net_revenue])",
            "lineageTag": "c9a59ddf-45f3-4522-b6b5-501c2f442768"
          },
          {
            "name": "Total Net Profit",
            "expression": "SUM(fact_sales[net_profit])",
            "lineageTag": "747fc106-6fb4-48f7-85cb-43581afa3402"
          },
          {
            "name": "Total Units Sold",
            "expression": "SUM(fact_sales[units_sold])",
            "lineageTag": "11d175e2-f1e5-45c9-8f60-e4c84f5101c2"
          },
          {
            "name": "Total Discount",
            "expression": "SUM(fact_sales[discount])",
            "lineageTag": "9cd693eb-d6eb-442a-a585-35a71cb6a4d1"
          },
          {
            "name": "Total Returns",
            "expression": "SUM(fact_sales[returns])",
            "lineageTag": "8670001a-15bc-468c-98ae-402d80a87686"
          },
          {
            "name": "Profit Margin %",
            "expression": "DIVIDE(SUM(fact_sales[net_profit]),SUM(fact_sales[revenue]),0)*100",
            "lineageTag": "9f8d6693-4726-4a65-bb51-e24e98a5dcb9"
          },
          {
            "name": "Discount Rate %",
            "expression": "DIVIDE(SUM(fact_sales[discount]),SUM(fact_sales[revenue]),0)*100",
            "lineageTag": "167c38dc-cf1e-4377-a90e-b82657a53429"
          },
          {
            "name": "Return Rate %",
            "expression": "DIVIDE(SUM(fact_sales[returns]),SUM(fact_sales[units_sold]),0)*100",
            "lineageTag": "c1e7054b-2efe-4030-99f6-5b1d4972072c"
          },
          {
            "name": "Avg Revenue per Unit",
            "expression": "DIVIDE(SUM(fact_sales[revenue]),SUM(fact_sales[units_sold]),0)",
            "lineageTag": "de21e43e-447a-41f2-8f3d-5c1e01c7b71b"
          }
        ],
        "partitions": [
          {
            "name": "fact_sales",
            "source": {
              "expression": [
                "let",
                "    Source    = Sql.Database(\"rcmgynklls5uvnpwnp7i3pdp3m-dvonkn4fn6lu7p6hoyzoit2bja.datawarehouse.fabric.microsoft.com\", \"NoVol_Project\", [CreateNavigationProperties=false]),",
                "    SqlResult = Value.NativeQuery(Source, \"SELECT date, product_id, product_name, category, region, channel, price, units_sold, revenue, discount, net_revenue, returns, net_profit, YEAR(date) AS year, MONTH(date) AS month, DATEPART(QUARTER, date) AS quarter, CAST(CASE WHEN revenue = 0 THEN 0 ELSE CAST(discount AS FLOAT) / revenue END AS FLOAT) AS discount_pct, CAST(CASE WHEN revenue = 0 THEN 0 ELSE CAST(net_profit AS FLOAT) / revenue END AS FLOAT) AS profit_margin_pct, CASE WHEN returns > 0 THEN 'Returned' ELSE 'No Return' END AS return_flag FROM dbo.fact_sales\", null, [EnableFolding=false])",
                "in  SqlResult"
              ],
              "type": "m"
            }
          }
        ]
