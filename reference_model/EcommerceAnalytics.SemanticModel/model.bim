        "lineageTag": "30f8f731-77ae-43d5-b3c1-568861561790",
        "partitions": [
          {
            "name": "revenue_by_product",
            "source": {
              "expression": [
                "let",
                "    Source    = Sql.Database(\"rcmgynklls5uvnpwnp7i3pdp3m-dvonkn4fn6lu7p6hoyzoit2bja.datawarehouse.fabric.microsoft.com\", \"NoVol_Project\", [CreateNavigationProperties=false]),",
                "    SqlResult = Value.NativeQuery(Source, \"SELECT dp.product_name, SUM(fs.revenue) AS total_revenue FROM dbo.fact_sales fs JOIN dbo.dim_product dp ON fs.product_id = dp.product_id JOIN dbo.dim_date dd ON fs.date = dd.date WHERE dd.year = YEAR(GETDATE()) - 1 GROUP BY dp.product_name\", null, [EnableFolding=true])",
                "in  SqlResult"
              ],
              "type": "m"
            }
          }
        ]
